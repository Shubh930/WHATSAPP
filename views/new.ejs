<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> write new chat</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h3>Create new chat..</h3>
    <form action="/chats" method="POST">
        <input type="text" name="from" placeholder="who r u ? "> <br><br>
        <textarea name="msg" id="" placeholder="Write your message here.."></textarea><br><br>
        <input type="text" name="to" placeholder="whom u r sending ? " ><br><br>
        <button class="bt">Create Chat</button>
    </form>
</body>
</html>